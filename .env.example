# ── Cloudprinter CloudCore 1.0 ──────────────────────────────────────────────
# Your API key from https://portal.cloudprinter.com
CLOUDPRINTER_API_KEY=41161cc34ed1dc29fbdae5eff0075c97

# Webhook key for validating incoming status-update callbacks from Cloudprinter
CLOUDPRINTER_WEBHOOK_KEY=f97440ee8591683ab4164ff10655aa42

# ── Vercel Blob (PDF file hosting) ──────────────────────────────────────────
# PDFs are uploaded to Vercel Blob Storage. The returned URL is permanent and
# public — Cloudprinter fetches it when the print job runs.
#
# Setup steps:
#   1. Open your Vercel project dashboard → Storage tab.
#   2. Click "Create Database" → choose "Blob".
#   3. Name it (e.g. "tpo-bizcards") and click "Create".
#   4. Go to the store's "Settings" or ".env.local" tab — copy the value of
#      BLOB_READ_WRITE_TOKEN into the field below.
#   5. Vercel automatically injects this variable into deployed functions;
#      for local dev add it to your .env file.
#
BLOB_READ_WRITE_TOKEN=your_vercel_blob_read_write_token

# ── Order notifications ──────────────────────────────────────────────────────
# Email address that receives Cloudprinter order confirmation and status emails.
ORDER_NOTIFICATION_EMAIL=d@tpo.group
