# ── Cloudprinter CloudCore 1.0 ──────────────────────────────────────────────
CLOUDPRINTER_API_KEY=your_cloudprinter_api_key
CLOUDPRINTER_WEBHOOK_KEY=your_cloudprinter_webhook_key

# ── Order notifications ──────────────────────────────────────────────────────
ORDER_NOTIFICATION_EMAIL=d@tpo.group

# ── File storage ─────────────────────────────────────────────────────────────
# Choose one of: LOCAL_STORAGE_DIR (testing) or S3_* variables (production)

# Local filesystem (for testing/dev)
LOCAL_STORAGE_DIR=/tmp/bizcards

# S3-compatible storage (for production)
# Works with AWS S3, Cloudflare R2, DigitalOcean Spaces, Backblaze B2, etc.
# Uncomment and configure these for production use:

# S3_ACCESS_KEY_ID=your_access_key_id
# S3_SECRET_ACCESS_KEY=your_secret_access_key
# S3_BUCKET=tpo-bizcards

# Leave blank for standard AWS S3. For other providers:
#   Cloudflare R2:       https://<account_id>.r2.cloudflarestorage.com
#   DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
# S3_ENDPOINT_URL=

# Region string. Use "auto" for Cloudflare R2, or your AWS region e.g. us-east-1
# S3_REGION=us-east-1

# Public base URL of the bucket (no trailing slash).
# Set this if your bucket is configured for public access — objects will be
# served as plain permanent URLs (recommended).
#   Cloudflare R2 public bucket: https://pub-<hash>.r2.dev
#   AWS S3 static website:       https://<bucket>.s3-website-<region>.amazonaws.com
# Leave blank to use 7-day presigned URLs instead (works without public access).
# S3_PUBLIC_URL=
